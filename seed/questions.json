    "questionId": "q-math-hard-001",
    "title": "If f(x) = 3x² - 2x + 1, what is f'(x)?",
    "questionType": "multiple_choice",
    "difficulty": "hard",
    "subject": "Mathematics",
    "grade": "Grade 9",
    "options": [
      { "text": "6x - 2", "isCorrect": true },
